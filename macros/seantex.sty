% Proof Box
\newtcolorbox{proofbox}[1][]{
    colback=white,
    colframe=gray!30,
    fonttitle=\bfseries\color{black}, % Keeps the base title font bold
    title={Proof\ifstrempty{#1}{}{ \textmd{#1}}}, % Adds a space and un-bolds the extra text
    arc=0pt,
    outer arc=0pt,
    boxrule=0.5pt,
    toprule=2pt, 
    enhanced,
    breakable,
    after upper={\hfill$\square$}
}

% Generic Neutral Box (Custom Title, No Numbering)
\newtcolorbox{notebox}[1]{
    colback=notecolor!5,
    colframe=notecolor,
    fonttitle=\bfseries,
    title={#1}, % This takes whatever you type in the brackets
    arc=3pt,
    outer arc=3pt,
    boxrule=0.8pt,
    % Optional: adds a slight emphasis to the left border
    leftrule=3pt 
}

% Dynamic Homework Box (Auto-numbered, customizable prefix)
\newtcolorbox[auto counter]{problem}[3][Problem]{
    colback=probcolor!5,
    colframe=probcolor,
    fonttitle=\bfseries,
    arc=3pt,
    outer arc=3pt,
    boxrule=0.8pt,
    % The logic below checks if a title was provided. 
    % If empty, it hides the colon.
    title={#1 \thetcbcounter\if\relax\detokenize{#2}\relax\else: #2\fi},
    label={#3}
    % Optional: adds a slight emphasis to the left border
    leftrule=3pt 
}

% Exercise Box
\newtcbtheorem[use counter from=theorem]{exercise}{Exercise}%
{
    colback=execolor!5,
    colframe=execolor,
    fonttitle=\bfseries,
    arc=3pt,
    outer arc=3pt,
    boxrule=0.8pt,
    % Optional: adds a slight emphasis to the left border
    leftrule=3pt 
}{exe}

% Warning Box
\newtcbtheorem{warning}{Warning}%
{
    colback=warncolor!5,
    colframe=warncolor,
    fonttitle=\bfseries,
    arc=3pt,
    outer arc=3pt,
    boxrule=0.8pt,
    leftrule=3pt,
}{warn}

% --- Math Commands ---
\newcommand{\N}{\mathbb{N}}
\newcommand{\Z}{\mathbb{Z}}
\newcommand{\Q}{\mathbb{Q}}
\newcommand{\R}{\mathbb{R}}
\newcommand{\C}{\mathbb{C}}
\newcommand{\powerset}{\mathcal{P}}


% --- General & Quality of Life ---
\newcommand{\F}{\mathbb{F}}                 % Generic field (R or C)
\newcommand{\eps}{\varepsilon}              % The "pretty" epsilon
\newcommand{\vphi}{\varphi}                 % The "pretty" phi

% --- Linear Algebra ---
% (Using \DeclareMathOperator so spacing is handled perfectly)
\DeclareMathOperator{\Span}{span}           % Span
\DeclareMathOperator{\Ker}{ker}             % Kernel
\DeclareMathOperator{\img}{im}              % Image (using \img to not break complex \Im)
\DeclareMathOperator{\rank}{rank}           % Rank
\DeclareMathOperator{\Tr}{Tr}               % Trace
\DeclareMathOperator{\diag}{diag}           % Diagonal matrix
\newcommand{\norm}[1]{\left\lVert#1\right\rVert}  % Norm ||v||
\newcommand{\abs}[1]{\left\lvert#1\right\rvert}   % Absolute value |x|
\newcommand{\inner}[2]{\left\langle#1, #2\right\rangle} % Inner product <u,v>

% --- Analysis II (Multivariable) ---
\newcommand{\dd}{\mathop{}\!\mathrm{d}}
\newcommand{\pd}[2]{\frac{\partial #1}{\partial #2}}               % First partial derivative
\newcommand{\pdd}[2]{\frac{\partial^2 #1}{\partial #2^2}}          % Second partial derivative (same variable)
\newcommand{\pddmix}[3]{\frac{\partial^2 #1}{\partial #2 \partial #3}} % Mixed partial derivative
\newcommand{\eval}[3]{\left. #1 \right|_{#2}^{#3}}                  % Evaluation bar for integrals
\newcommand{\interior}[1]{%
  {\kern0pt#1}^{\mathrm{o}}%
}

