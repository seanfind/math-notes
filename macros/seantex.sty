% --- Custom Box Styles ---

% Theorem Box
\newtcbtheorem[number within=section]{theorem}{Theorem}%
{
    colback=thmcolor!5,
    colframe=thmcolor,
    fonttitle=\bfseries,
    arc=3pt,
    outer arc=3pt,
    boxrule=0.8pt,
    % Optional: adds a slight emphasis to the left border
    leftrule=3pt 
}{thm}

% Lemma Box
\newtcbtheorem[use counter from=theorem]{lemma}{Lemma}%
{
    colback=lemcolor!5,
    colframe=lemcolor,
    fonttitle=\bfseries,
    arc=3pt,
    outer arc=3pt,
    boxrule=0.8pt,
    % Optional: adds a slight emphasis to the left border
    leftrule=3pt 
}{lem}

% Corollary Box
\newtcbtheorem[use counter from=theorem]{corollary}{Corollary}%
{
